import tkinter as tk
from tkinter import ttk, messagebox
import json
import os

DATA_FILE = "movies.json"

def load_movies():
    if not os.path.exists(DATA_FILE):
        return []
    with open(DATA_FILE, "r", encoding="utf-8") as f:
        return json.load(f)

def save_movies(movies):
    with open(DATA_FILE, "w", encoding="utf-8") as f:
        json.dump(movies, f, indent=4, ensure_ascii=False)

class MovieLibrary:
    def __init__(self, root):
        self.root = root
        self.root.title("Movie Library - Личная кинотека")
        self.root.geometry("800x500")

        self.movies = load_movies()
        self.filtered_movies = self.movies[:]

        tk.Label(root, text="Название:").grid(row=0, column=0, padx=5, pady=5)
        self.title_entry = tk.Entry(root, width=30)
        self.title_entry.grid(row=0, column=1, padx=5, pady=5)

        tk.Label(root, text="Жанр:").grid(row=0, column=2, padx=5, pady=5)
        self.genre_entry = tk.Entry(root, width=20)
        self.genre_entry.grid(row=0, column=3, padx=5, pady=5)

        tk.Label(root, text="Год выпуска:").grid(row=1, column=0, padx=5, pady=5)
        self.year_entry = tk.Entry(root, width=10)
        self.year_entry.grid(row=1, column=1, padx=5, pady=5)

        tk.Label(root, text="Рейтинг (0-10):").grid(row=1, column=2, padx=5, pady=5)
        self.rating_entry = tk.Entry(root, width=10)
        self.rating_entry.grid(row=1, column=3, padx=5, pady=5)

        self.add_btn = tk.Button(root, text="Добавить фильм", command=self.add_movie)
        self.add_btn.grid(row=2, column=0, columnspan=4, pady=10)

        tk.Label(root, text="Фильтр по жанру:").grid(row=3, column=0, padx=5, pady=5)
        self.filter_genre = tk.Entry(root, width=20)
        self.filter_genre.grid(row=3, column=1, padx=5, pady=5)

        tk.Label(root, text="Фильтр по году:").grid(row=3, column=2, padx=5, pady=5)
        self.filter_year = tk.Entry(root, width=10)
        self.filter_year.grid(row=3, column=3, padx=5, pady=5)

        self.filter_btn = tk.Button(root, text="Применить фильтр", command=self.apply_filter)
        self.filter_btn.grid(row=4, column=0, columnspan=2, pady=5)

        self.reset_btn = tk.Button(root, text="Сбросить фильтр", command=self.reset_filter)
        self.reset_btn.grid(row=4, column=2, columnspan=2, pady=5)

        columns = ("Название", "Жанр", "Год", "Рейтинг")
        self.tree = ttk.Treeview(root, columns=columns, show="headings")
        for col in columns:
            self.tree.heading(col, text=col)
            self.tree.column(col, width=150)

        self.tree.grid(row=5, column=0, columnspan=4, padx=10, pady=10, sticky="nsew")

        scrollbar = ttk.Scrollbar(root, orient=tk.VERTICAL, command=self.tree.yview)
        scrollbar.grid(row=5, column=4, sticky="ns")
        self.tree.configure(yscrollcommand=scrollbar.set)

        root.grid_rowconfigure(5, weight=1)
        root.grid_columnconfigure(0, weight=1)

        self.refresh_table()

    def add_movie(self):
        title = self.title_entry.get().strip()
        genre = self.genre_entry.get().strip()
        year_str = self.year_entry.get().strip()
        rating_str = self.rating_entry.get().strip()

        if not title or not genre or not year_str or not rating_str:
            messagebox.showerror("Ошибка", "Заполните все поля!")
            return

        try:
            year = int(year_str)
        except ValueError:
            messagebox.showerror("Ошибка", "Год должен быть числом!")
            return

        try:
            rating = float(rating_str)
            if rating < 0 or rating > 10:
                raise ValueError
        except ValueError:
            messagebox.showerror("Ошибка", "Рейтинг должен быть числом от 0 до 10!")
            return

        new_movie = {
            "title": title,
            "genre": genre,
            "year": year,
            "rating": rating
        }
        self.movies.append(new_movie)
        save_movies(self.movies)
        self.reset_filter()
        self.clear_entries()
        messagebox.showinfo("Успех", "Фильм добавлен!")

    def clear_entries(self):
        self.title_entry.delete(0, tk.END)
        self.genre_entry.delete(0, tk.END)
        self.year_entry.delete(0, tk.END)
        self.rating_entry.delete(0, tk.END)

    def apply_filter(self):
        genre_filter = self.filter_genre.get().strip().lower()
        year_filter = self.filter_year.get().strip()

        self.filtered_movies = self.movies[:]

        if genre_filter:
            self.filtered_movies = [m for m in self.filtered_movies if genre_filter in m["genre"].lower()]

        if year_filter:
            try:
                year_int = int(year_filter)
                self.filtered_movies = [m for m in self.filtered_movies if m["year"] == year_int]
            except ValueError:
                messagebox.showerror("Ошибка", "Год фильтрации должен быть числом!")
                return

        self.refresh_table()

    def reset_filter(self):
        self.filter_genre.delete(0, tk.END)
        self.filter_year.delete(0, tk.END)
        self.filtered_movies = self.movies[:]
        self.refresh_table()

    def refresh_table(self):
        for row in self.tree.get_children():
            self.tree.delete(row)

        for movie in self.filtered_movies:
            self.tree.insert("", tk.END, values=(
                movie["title"], movie["genre"], movie["year"], movie["rating"]
            ))

if __name__ == "__main__":
    root = tk.Tk()
    app = MovieLibrary(root)
    root.mainloop()
